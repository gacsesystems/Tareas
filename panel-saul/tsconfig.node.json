{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"noEmit": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
	},
	"include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts", "eslint.config.js", "tailwind.config.js"]
}
